linters: linters_with_defaults(
    # Line length - be generous for Shiny apps with long UI definitions
    line_length_linter(120),
    # Disable some overly strict linters for existing codebase
    object_name_linter = NULL,        # Allow existing naming conventions
    cyclocomp_linter = NULL,          # Complex functions OK in Shiny
    object_length_linter = NULL,      # Long names OK for clarity
    # Keep these important checks
    assignment_linter(),              # Use <- not =
    whitespace_linter(),              # No tabs (renamed from no_tab_linter in lintr 3.1)
    trailing_blank_lines_linter(),    # Clean file endings
    trailing_whitespace_linter()      # No trailing spaces
  )
exclusions: list(
    "metawebs/arctic/infomap_ecology_package",
    "metawebs/atlantic/NorthSeaFoodWeb",
    "archive",
    "tests/debug",
    "renv"
  )
encoding: "UTF-8"
